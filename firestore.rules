rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // config/demo passcode must be readable without auth so the login page
    // can validate the funder passcode before any Firebase session exists.
    match /config/demo {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // All authenticated users (signed-in @housingopps.org accounts) can read
    // and write any collection. The security boundary is Google login — only
    // staff with an org account can reach this app.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

  }
}
